POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

APP_JWT_SECRET=change-this-secret-key-to-at-least-32-characters-long-for-dev
APP_INTERNAL_API_KEY=change-this-contract-internal-api-key
APP_CORS_ALLOWED_ORIGIN=http://localhost:3000
APP_JPA_DDL_AUTO=update
APP_FLYWAY_ENABLED=true
APP_FLYWAY_BASELINE_ON_MIGRATE=true
APP_DOCS_ENABLED=true
APP_SQL_LOG_LEVEL=debug
APP_SECURITY_LOG_LEVEL=info
APP_GATEWAY_LOG_LEVEL=info
APP_AUTH_RATE_LIMIT_ENABLED=true
APP_AUTH_RATE_LIMIT_TRUST_FORWARDED_FOR=true
APP_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
APP_AUTH_LOGIN_MAX_REQUESTS=10
APP_AUTH_REGISTER_MAX_REQUESTS=5
APP_AUTH_REFRESH_MAX_REQUESTS=20
APP_SECURITY_HSTS_ENABLED=false
APP_SECURITY_HSTS_MAX_AGE_SECONDS=31536000
APP_AUTH_COOKIE_ACCESS_NAME=sb_access_token
APP_AUTH_COOKIE_REFRESH_NAME=sb_refresh_token
APP_AUTH_COOKIE_SECURE=false
APP_AUTH_COOKIE_SAME_SITE=Lax
APP_AUTH_COOKIE_DOMAIN=
APP_AUTH_COOKIE_ACCESS_PATH=/
APP_AUTH_COOKIE_REFRESH_PATH=/auth
APP_OUTBOX_ENABLED=true
APP_OUTBOX_BATCH_SIZE=50
APP_OUTBOX_DISPATCH_INTERVAL_MS=5000
APP_OUTBOX_INITIAL_RETRY_DELAY_SECONDS=5
APP_OUTBOX_RETRY_MULTIPLIER=2.0
APP_OUTBOX_MAX_RETRY_DELAY_SECONDS=300

ENABLE_ADVANCED_SEARCH=false
SEARCH_PROVIDER=db
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX_JOBS=jobs
OPENSEARCH_INDEX_COMPANIES=companies
OPENSEARCH_CONNECT_TIMEOUT_MS=3000
OPENSEARCH_SOCKET_TIMEOUT_MS=5000
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

ENABLE_FILE_STORAGE=true
STORAGE_PROVIDER=mock
MAX_CV_FILE_SIZE_MB=10
CV_SIGNED_URL_TTL_MINUTES=15
ALLOWED_CV_CONTENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
MOCK_STORAGE_BASE_DIR=
MOCK_STORAGE_BUCKET=mock-local
S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

