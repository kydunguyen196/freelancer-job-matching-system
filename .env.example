POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

APP_JWT_SECRET=change-this-secret-key-to-at-least-32-characters-long-for-dev
APP_INTERNAL_API_KEY=change-this-contract-internal-api-key
APP_CORS_ALLOWED_ORIGIN=http://localhost:3000

ENABLE_ADVANCED_SEARCH=true
SEARCH_PROVIDER=opensearch
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX_JOBS=jobs
OPENSEARCH_INDEX_COMPANIES=companies
OPENSEARCH_CONNECT_TIMEOUT_MS=3000
OPENSEARCH_SOCKET_TIMEOUT_MS=5000
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

ENABLE_FILE_STORAGE=true
STORAGE_PROVIDER=minio
MAX_CV_FILE_SIZE_MB=10
CV_SIGNED_URL_TTL_MINUTES=15
ALLOWED_CV_CONTENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=skillbridge-cv
MINIO_REGION=us-east-1
MINIO_SECURE=false

ENABLE_EMAIL=false
SENDGRID_API_KEY=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=SkillBridge

ENABLE_CALENDAR=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth2/callback/google
GOOGLE_CALENDAR_ID=
GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar
GOOGLE_REFRESH_TOKEN=
