SPRING_PROFILES_ACTIVE=prod

POSTGRES_USER=skillbridge
POSTGRES_PASSWORD=change-this-db-password
RABBITMQ_USERNAME=skillbridge
RABBITMQ_PASSWORD=change-this-rabbitmq-password

APP_JWT_SECRET=replace-with-a-long-random-secret
APP_INTERNAL_API_KEY=replace-with-a-long-random-internal-key
APP_CORS_ALLOWED_ORIGIN=https://app.example.com
APP_JPA_DDL_AUTO=validate
APP_FLYWAY_ENABLED=true
APP_FLYWAY_BASELINE_ON_MIGRATE=true
APP_DOCS_ENABLED=false
APP_SQL_LOG_LEVEL=warn
APP_SECURITY_LOG_LEVEL=warn
APP_GATEWAY_LOG_LEVEL=info
APP_AUTH_RATE_LIMIT_ENABLED=true
APP_AUTH_RATE_LIMIT_TRUST_FORWARDED_FOR=true
APP_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
APP_AUTH_LOGIN_MAX_REQUESTS=10
APP_AUTH_REGISTER_MAX_REQUESTS=5
APP_AUTH_REFRESH_MAX_REQUESTS=20
APP_SECURITY_HSTS_ENABLED=true
APP_SECURITY_HSTS_MAX_AGE_SECONDS=31536000

ENABLE_ADVANCED_SEARCH=true
SEARCH_PROVIDER=opensearch
OPENSEARCH_URL=https://opensearch.example.com
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX_JOBS=jobs
OPENSEARCH_INDEX_COMPANIES=companies
OPENSEARCH_CONNECT_TIMEOUT_MS=3000
OPENSEARCH_SOCKET_TIMEOUT_MS=5000

ENABLE_FILE_STORAGE=true
STORAGE_PROVIDER=s3
MAX_CV_FILE_SIZE_MB=10
CV_SIGNED_URL_TTL_MINUTES=15
ALLOWED_CV_CONTENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
S3_BUCKET=skillbridge-cv
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

ENABLE_EMAIL=true
SENDGRID_API_KEY=
MAIL_FROM_EMAIL=no-reply@example.com
MAIL_FROM_NAME=SkillBridge
SENDGRID_BASE_URL=https://api.sendgrid.com
EMAIL_MAX_ATTEMPTS=5
EMAIL_INITIAL_RETRY_DELAY_SECONDS=60
EMAIL_RETRY_MULTIPLIER=2.0
EMAIL_RETRY_POLL_DELAY_MS=60000

ENABLE_CALENDAR=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.example.com/oauth2/callback/google
GOOGLE_CALENDAR_ID=
GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar
GOOGLE_REFRESH_TOKEN=
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_API_BASE_URL=https://www.googleapis.com
